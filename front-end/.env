# Copy this file to .env and fill in your values

# URL of the API Gateway endpoint that proxies to the Bedrock Agent
# Set by the backend team once the agent is deployed
VITE_CHAT_API_URL=/api/chat

# URL of the API Gateway endpoint that returns the car inventory
# Expected: GET /cars  →  Car[] (see knowledge-base/products.json for shape)
VITE_CARS_API_URL=https://your-api-gateway-url/cars
